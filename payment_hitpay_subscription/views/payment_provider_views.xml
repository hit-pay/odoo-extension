<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">HitPay Payment Gateway Subscription Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <group invisible="code != 'hitpay_subscription'">
                    <field name="hitpay_subscription_api_key" string="API Key" required="code == 'hitpay_subscription' and state != 'disabled'" />
                    <field name="hitpay_subscription_api_salt" string="Salt" required="code == 'hitpay_subscription' and state != 'disabled'" password="True"/>
										<field name="hitpay_debug_logging" string="API Logging"	invisible="code != 'hitpay_subscription' or state == 'disabled'" />
                </group>
            </group>
        </field>
    </record>
	
</odoo>
